generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Signup {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  trading_type    String   // crypto | stocks | both
  referral_source String   // twitter | instagram | tiktok | youtube | reddit | friend | google | other
  createdAt       DateTime @default(now())
}
